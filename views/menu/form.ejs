<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= item ? 'Muuda rooga' : 'Lisa roog' %> — SHOYU Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container mt-4" style="max-width:720px">
    <div class="mb-4">
      <a href="/admin/menu" class="text-decoration-none text-muted">← Tagasi menüüsse</a>
    </div>

    <h1 class="h3 mb-4"><%= item ? 'Muuda rooga' : 'Lisa uus roog' %></h1>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form
      action="/admin/menu/<%= item ? item.id + '/edit' : 'new' %>"
      method="POST"
      enctype="multipart/form-data"
      novalidate
    >
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="row g-3">

        <!-- Nimi -->
        <div class="col-12">
          <label class="form-label fw-semibold" for="name">
            Nimi <span class="text-danger">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            class="form-control"
            value="<%= item ? item.name : '' %>"
            placeholder="nt. Tonkotsu Ramen"
            required
          >
        </div>

        <!-- Kategooria -->
        <div class="col-sm-6">
          <label class="form-label fw-semibold" for="category">
            Kategooria <span class="text-danger">*</span>
          </label>
          <select id="category" name="category" class="form-select" required>
            <% const cats = ['Eripakkumised','Eelroad & Suupisted','Ramen','Kõrvale','Magustoit','Joogid']; %>
            <% cats.forEach(c => { %>
              <option value="<%= c %>" <%= item && item.category === c ? 'selected' : '' %>><%= c %></option>
            <% }) %>
          </select>
        </div>

        <!-- Hind -->
        <div class="col-sm-3">
          <label class="form-label fw-semibold" for="price">
            Hind (€) <span class="text-danger">*</span>
          </label>
          <input
            type="number"
            id="price"
            name="price"
            class="form-control"
            value="<%= item ? item.price : '' %>"
            min="0"
            step="0.01"
            placeholder="0.00"
            required
          >
        </div>

        <!-- Vürtsisus -->
        <div class="col-sm-3">
          <label class="form-label fw-semibold" for="spiciness">Vürtsisus</label>
          <select id="spiciness" name="spiciness" class="form-select">
            <option value="0" <%= item && item.spiciness == 0 ? 'selected' : (!item ? 'selected' : '') %>>0 — Ei ole</option>
            <option value="1" <%= item && item.spiciness == 1 ? 'selected' : '' %>>1 🌶️ — Kergelt</option>
            <option value="2" <%= item && item.spiciness == 2 ? 'selected' : '' %>>2 🌶️🌶️ — Keskmiselt</option>
            <option value="3" <%= item && item.spiciness == 3 ? 'selected' : '' %>>3 🌶️🌶️🌶️ — Väga vürtsikas</option>
          </select>
        </div>

        <!-- Kirjeldus -->
        <div class="col-12">
          <label class="form-label fw-semibold" for="description">Kirjeldus</label>
          <textarea
            id="description"
            name="description"
            class="form-control"
            rows="3"
            placeholder="Lühike kirjeldus roa kohta..."
          ><%= item ? item.description : '' %></textarea>
        </div>

        <!-- Koostis -->
        <div class="col-md-6">
          <label class="form-label fw-semibold" for="ingredients">
            Koostis
            <small class="text-muted fw-normal">(komadega eraldatud)</small>
          </label>
          <textarea
            id="ingredients"
            name="ingredients"
            class="form-control"
            rows="3"
            placeholder="nt. Seapuljong, ramenunuudlid, chashu, muna"
          ><%= item ? item.ingredients : '' %></textarea>
        </div>

        <!-- Allergeenid -->
        <div class="col-md-6">
          <label class="form-label fw-semibold" for="allergens">
            Allergeenid
            <small class="text-muted fw-normal">(komadega eraldatud)</small>
          </label>
          <textarea
            id="allergens"
            name="allergens"
            class="form-control"
            rows="3"
            placeholder="nt. Gluteen, muna, sojauba"
          ><%= item ? item.allergens : '' %></textarea>
        </div>

        <!-- Pilt -->
        <div class="col-12">
          <label class="form-label fw-semibold" for="image">Pilt</label>
          <% if (item && item.image) { %>
            <div class="mb-2">
              <img
                src="<%= item.image %>"
                alt="Praegune pilt"
                width="120"
                height="80"
                style="object-fit:cover;border-radius:6px;border:1px solid #dee2e6"
              >
              <div class="text-muted small mt-1">Praegune pilt — uue faili valimisel asendatakse</div>
            </div>
          <% } %>
          <input
            type="file"
            id="image"
            name="image"
            class="form-control"
            accept="image/*"
          >
          <div class="form-text">Max 5 MB. Toetatud: JPG, PNG, WebP, GIF.</div>
        </div>

        <!-- Uus badge -->
        <div class="col-12">
          <div class="form-check">
            <input
              type="checkbox"
              id="is_new"
              name="is_new"
              class="form-check-input"
              value="1"
              <%= item && item.is_new ? 'checked' : '' %>
            >
            <label class="form-check-label" for="is_new">
              Märgi "Uus" &#8212; kuvatakse esiküljel ja menüüs uue tähistusega
            </label>
          </div>
        </div>

      </div>

      <hr class="my-4">

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4">
          <%= item ? 'Salvesta muudatused' : 'Lisa roog' %>
        </button>
        <a href="/admin/menu" class="btn btn-outline-secondary">Tühista</a>
      </div>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
