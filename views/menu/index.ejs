<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Menüühaldus — SHOYU Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/nav') %>

  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0">Menüühaldus</h1>
      <a href="/admin/menu/new" class="btn btn-primary">+ Lisa roog</a>
    </div>

    <% const categories = [...new Set(items.map(i => i.category))]; %>

    <% if (items.length === 0) { %>
      <div class="alert alert-info">Menüüs pole ühtegi rooga. <a href="/admin/menu/new">Lisa esimene!</a></div>
    <% } else { %>
      <% categories.forEach(cat => { %>
        <h5 class="mt-4 mb-2 text-muted text-uppercase small fw-bold"><%= cat %></h5>
        <div class="table-responsive">
          <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th style="width:60px">Pilt</th>
                <th>Nimi</th>
                <th>Hind</th>
                <th style="width:100px">Vürtsisus</th>
                <th>Uus?</th>
                <th style="width:140px">Toimingud</th>
              </tr>
            </thead>
            <tbody>
              <% items.filter(i => i.category === cat).forEach(item => { %>
                <tr>
                  <td>
                    <% if (item.image) { %>
                      <img src="<%= item.image %>" alt="" width="48" height="48" style="object-fit:cover;border-radius:4px">
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="fw-semibold"><%= item.name %></div>
                    <div class="text-muted small text-truncate" style="max-width:240px"><%= item.description %></div>
                  </td>
                  <td><%= item.price.toFixed(2) %> €</td>
                  <td>
                    <% for (let s=0; s<item.spiciness; s++) { %><span title="Vürtsikas">🌶️</span><% } %>
                    <% if (item.spiciness === 0) { %><span class="text-muted">—</span><% } %>
                  </td>
                  <td>
                    <% if (item.is_new) { %><span class="badge bg-warning text-dark">Uus</span><% } else { %>—<% } %>
                  </td>
                  <td>
                    <a href="/admin/menu/<%= item.id %>/edit" class="btn btn-sm btn-outline-primary me-1">Muuda</a>
                    <form action="/admin/menu/<%= item.id %>/delete" method="POST" class="d-inline"
                          onsubmit="return confirm('Kustuta roog <%= item.name %>?')">
                      <button class="btn btn-sm btn-outline-danger">Kustuta</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% }) %>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
