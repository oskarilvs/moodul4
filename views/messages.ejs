<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Kontaktisõnumid — SHOYU Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/nav') %>

  <div class="container mt-4">
    <h1 class="h3 mb-4">Kontaktisõnumid</h1>

    <% if (messages.length === 0) { %>
      <div class="alert alert-info">Sõnumeid pole veel.</div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-bordered table-hover">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Nimi</th>
              <th>E-post</th>
              <th>Teema</th>
              <th>Sõnum</th>
              <th>Saadetud</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% messages.forEach(msg => { %>
              <tr>
                <td class="text-muted small"><%= msg.id %></td>
                <td><%= msg.name %></td>
                <td><a href="mailto:<%= msg.email %>"><%= msg.email %></a></td>
                <td><%= msg.subject || '—' %></td>
                <td>
                  <span
                    class="d-inline-block text-truncate"
                    style="max-width:240px"
                    title="<%= msg.message %>"
                  ><%= msg.message %></span>
                </td>
                <td class="text-muted small text-nowrap"><%= msg.sent_at %></td>
                <td>
                  <form
                    action="/admin/messages/<%= msg.id %>/delete"
                    method="POST"
                    onsubmit="return confirm('Kustuta sõnum?')"
                  >
                    <button class="btn btn-sm btn-outline-danger">Kustuta</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
