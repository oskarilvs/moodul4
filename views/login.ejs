<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Sisselogimine — SHOYU Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark d-flex align-items-center justify-content-center min-vh-100">
  <div class="card shadow" style="width:100%;max-width:420px">
    <div class="card-body p-4">
      <h1 class="h4 mb-1 text-center fw-bold">🍜 SHOYU & CO.</h1>
      <p class="text-muted text-center mb-4">Admin paneel</p>

      <% if (error) { %>
        <div class="alert alert-danger py-2"><%= error %></div>
      <% } %>

      <form action="/admin/login" method="POST" novalidate>
        <div class="mb-3">
          <label class="form-label" for="email">E-post</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-control"
            placeholder="admin@shoyu.ee"
            required
            autofocus
          >
        </div>
        <div class="mb-4">
          <label class="form-label" for="password">Parool</label>
          <input
            type="password"
            id="password"
            name="password"
            class="form-control"
            placeholder="••••••••"
            required
          >
        </div>
        <button type="submit" class="btn btn-primary w-100">Logi sisse</button>
      </form>
    </div>
  </div>
</body>
</html>
