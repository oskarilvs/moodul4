<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Töölaud — SHOYU Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/nav') %>

  <div class="container mt-4">
    <h1 class="h3 mb-4">Töölaud</h1>

    <div class="row g-3 mb-5">
      <div class="col-sm-6 col-md-3">
        <div class="card text-bg-primary">
          <div class="card-body">
            <div class="fs-1 fw-bold"><%= menuCount %></div>
            <div>Menüükirjet</div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-md-3">
        <div class="card text-bg-success">
          <div class="card-body">
            <div class="fs-1 fw-bold"><%= msgCount %></div>
            <div>Kontaktisõnumit</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-6">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span>Viimased sõnumid</span>
            <a href="/admin/messages" class="btn btn-sm btn-outline-secondary">Kõik</a>
          </div>
          <% if (latest.length === 0) { %>
            <div class="card-body text-muted">Sõnumeid pole veel.</div>
          <% } else { %>
            <ul class="list-group list-group-flush">
              <% latest.forEach(msg => { %>
                <li class="list-group-item">
                  <div class="fw-semibold"><%= msg.name %> <small class="text-muted fw-normal">&lt;<%= msg.email %>&gt;</small></div>
                  <div class="text-muted small"><%= msg.subject || '(teemata)' %> &mdash; <span><%= msg.sent_at %></span></div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card">
          <div class="card-header">Kiirlingid</div>
          <div class="card-body d-grid gap-2">
            <a href="/admin/menu/new" class="btn btn-primary">+ Lisa uus roog</a>
            <a href="/admin/menu" class="btn btn-outline-primary">Menüühaldus</a>
            <a href="/admin/messages" class="btn btn-outline-secondary">Kontaktisõnumid</a>
            <hr>
            <a href="/api/menu" class="btn btn-outline-dark" target="_blank">REST API — GET /api/menu</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
